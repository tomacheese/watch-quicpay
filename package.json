{
  "name": "watch-quicpay",
  "version": "1.0.0",
  "description": "Notify new campaign information added to the QUICPay campaign list page via Discord.",
  "homepage": "https://github.com/tomacheese/watch-quicpay",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-quicpay/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:tomacheese/watch-quicpay.git",
    "type": "git"
  },
  "scripts": {
    "generate-schema": "typescript-json-schema --required tsconfig.json Configuration -o schema/Configuration.json",
    "test": "jest",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "fix": "run-z fix:prettier,fix:eslint"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@book000/node-utils": "1.24.239",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.2",
    "cheerio": "1.2.0",
    "eslint": "10.5.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "prettier": "3.8.4",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-json-schema": "0.67.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "moduleNameMapper": {
      "@/(.+)": "<rootDir>/src/$1"
    },
    "transform": {
      ".+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ]
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
