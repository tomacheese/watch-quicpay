{
  "name": "watch-quicpay",
  "version": "1.0.0",
  "description": "Notify new campaign information added to the QUICPay campaign list page via Discord.",
  "homepage": "https://github.com/tomacheese/watch-quicpay",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-quicpay/issues"
  },
  "license": "MIT",
  "author": "Tomachi",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:tomacheese/watch-quicpay.git",
    "type": "git"
  },
  "scripts": {
    "generate-schema": "typescript-json-schema --required tsconfig.json Configuration -o schema/Configuration.json",
    "test": "jest",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "dev": "tsx watch ./src/main.ts",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "fix": "run-z fix:prettier,fix:eslint"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.14.24",
    "@book000/node-utils": "1.24.157",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "cheerio": "1.2.0",
    "eslint": "10.3.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "run-z": "2.1.0",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "moduleNameMapper": {
      "@/(.+)": "<rootDir>/src/$1"
    },
    "transform": {
      ".+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ]
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
